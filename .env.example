# ===========================
# AI Donor Matcher — Environment Variables
# ===========================
# Copy this file to .env and fill in your values
# .env is gitignored by default

# DATABASE (PostgreSQL - Cloud)
DB_URL=jdbc:postgresql://<your-cloud-db-host>:<port>/<dbname>?sslmode=require
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-db-password>

# JWT (Generate a secure base64 string)
JWT_SECRET=your-256-bit-base64-encoded-secret-here
JWT_EXPIRATION_MS=86400000

# Email (Resend HTTPS API)
EMAIL_PROVIDER=resend
EMAIL_RESEND_BASE_URL=https://api.resend.com
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=AI Donor Matcher <noreply@yourdomain.com>

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App Configuration
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,https://*.vercel.app
