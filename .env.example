# ===========================
# AI Donor Matcher — Environment Variables
# ===========================
# Copy this file to .env and fill in your values
# .env is gitignored by default

# DATABASE (PostgreSQL - Cloud)
DB_URL=jdbc:postgresql://<your-cloud-db-host>:<port>/<dbname>?sslmode=require
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-db-password>

# JWT (Generate a secure base64 string)
JWT_SECRET=your-256-bit-base64-encoded-secret-here
JWT_EXPIRATION_MS=86400000

# Transactional email only (optional in production if Firebase handles auth mail)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=AI Donor Matcher <noreply@yourdomain.com>

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Firebase (Web App)
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# Firebase Admin (Backend Verification)
# Preferred for local and hosting:
FIREBASE_ADMIN_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}
# Optional local fallback only:
FIREBASE_ADMIN_CREDENTIALS_PATH=
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App Configuration
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,https://*.vercel.app
FIREBASE_MIGRATION_ENABLED=false
