# ===========================
# AI Donor Matcher — Environment Variables
# ===========================
# Copy this file to .env and fill in your values
# .env is gitignored by default

# DATABASE (PostgreSQL - Cloud)
DB_URL=jdbc:postgresql://<your-cloud-db-host>:<port>/<dbname>?sslmode=require
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-db-password>

# JWT (Generate a secure base64 string)
JWT_SECRET=your-256-bit-base64-encoded-secret-here
JWT_EXPIRATION_MS=86400000

# Email (Gmail SMTP - Use an App Password)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App Configuration
APP_BASE_URL=http://localhost:5173
